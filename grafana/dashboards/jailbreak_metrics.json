{
  "title": "Yucatan Slang Jailbreak Benchmark",
  "uid": "slang-bench-dash",
  "description": "Live metrics for the Yucatan Slang Jailbreak Benchmark.",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "title": "Total Attack Attempts",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COUNT(*) FROM results;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "title": "Overall Jailbreak Success Rate",
      "type": "stat",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 3,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COALESCE(AVG(jailbreak_success::int) * 100, 0) AS success_rate FROM results;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 50,
                "color": "orange"
              },
              {
                "value": 80,
                "color": "red"
              }
            ]
          }
        }
      }
    },
    {
      "title": "Average Judge Confidence",
      "type": "gauge",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COALESCE(AVG(confidence) * 100, 0) FROM results;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "continuous-BlPu"
          }
        }
      }
    },
    {
      "title": "Success Rate by Target Model",
      "type": "bargauge",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT target_model, AVG(jailbreak_success::int) * 100 AS success_rate FROM results GROUP BY target_model ORDER BY success_rate DESC;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal"
      }
    },
    {
      "title": "Most Vulnerable Harm Categories",
      "type": "piechart",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT j.harm_category, AVG(r.jailbreak_success::int) * 100 AS success_rate FROM results r JOIN jerga j ON r.jerga_id = j.id GROUP BY j.harm_category;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      },
      "options": {
        "pieType": "donut",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "title": "Jailbreak Severity Breakdown",
      "type": "piechart",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT severity, COUNT(*) FROM results WHERE jailbreak_success = true GROUP BY severity;",
          "format": "table"
        }
      ],
      "options": {
        "pieType": "pie"
      }
    },
    {
      "title": "Most Dangerous Slang Terms",
      "type": "bargauge",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT j.term, AVG(r.jailbreak_success::int) * 100 AS success_rate FROM results r JOIN jerga j ON r.jerga_id = j.id GROUP BY j.term ORDER BY success_rate DESC LIMIT 5;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "continuous-GrYlRd"
          }
        }
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal"
      }
    },
    {
      "title": "Success Rate by Attack Technique",
      "type": "barchart",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 10
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT attack_technique, AVG(jailbreak_success::int) * 100 AS success_rate FROM results GROUP BY attack_technique ORDER BY success_rate DESC;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "orientation": "auto"
      }
    },
    {
      "title": "Attacks Over Time",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT created_at AS time, COUNT(*) AS attacks FROM results GROUP BY time ORDER BY time ASC;",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "title": "Recent Successful Jailbreaks",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT target_model, attack_technique, severity, generated_prompt FROM results WHERE jailbreak_success = true ORDER BY created_at DESC LIMIT 10;",
          "format": "table"
        }
      ]
    },
    {
      "title": "Average Slang Integration Score (SIS)",
      "type": "gauge",
      "datasource": {
        "type": "postgres",
        "uid": "PostgreSQL"
      },
      "gridPos": {
        "h": 4,
        "w": 3,
        "x": 9,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT COALESCE(AVG(slang_integration_score), 0) FROM results;",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "color": {
            "mode": "continuous-BlPu"
          }
        }
      }
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}