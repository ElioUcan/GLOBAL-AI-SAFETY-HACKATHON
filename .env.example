# ── Copy to .env and fill in. compose.yml reads these. ──────────────

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=slang_bench
POSTGRES_PORT=5432

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=please-change-this-key

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# Misc
TZ=America/Merida

# LLM provider — NVIDIA NIM (attacker, judge, SIS, and all default targets)
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Optional model overrides (all nvidia_nim/* slugs)
# ATTACKER_DEFAULT_MODEL=nvidia_nim/meta/llama-3.1-70b-instruct
# ATTACKER_VALIDATION_MODEL=nvidia_nim/meta/llama-3.3-70b-instruct
# ATTACKER_FALLBACK_MODEL=nvidia_nim/nvidia/nemotron-3-super-120b-a12b
# JUDGE_MODEL=nvidia_nim/meta/llama-3.1-70b-instruct
# SIS_EVALUATOR_MODEL=nvidia_nim/meta/llama-3.1-70b-instruct
# DEFAULT_TARGET_MODEL=nvidia_nim/meta/llama-3.1-8b-instruct

# Victim (target) max completion tokens — override with --target-max-tokens on CLI
TARGET_MAX_TOKENS=579

# Attacker max completion tokens — override with --attacker-max-tokens on CLI
ATTACKER_MAX_TOKENS=256

# Optional — OpenRouter only if you explicitly pass openrouter/* slugs on CLI
# OPENROUTER_API_KEY=
# OPENROUTER_API_BASE=
