# ── Copy to .env and fill in. compose.yml reads these. ──────────────

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=slang_bench
POSTGRES_PORT=5432

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=please-change-this-key

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# Misc
TZ=America/Merida

# LiteLLM Proxy (central gateway — all LLM calls route here)
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-litellm-master-key
LITELLM_BASE_URL=http://localhost:4000
LITELLM_PROVIDER_MODE=nim

# Provider keys (stored in litellm container only — not exposed to n8n nodes)
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
OPENROUTER_API_KEY=

# Attacker alias overrides (optional)
# ATTACKER_DEFAULT_ALIAS=attacker-base
# ATTACKER_VALIDATION_ALIAS=attacker-validation
# ATTACKER_FALLBACK_ALIAS=attacker-fallback

# Regex pre-filter: false = signal to Judge (recommended); true = skip Judge on match
REGEX_DECIDES_RESULT=false

# CLI local runs (host → docker postgres)
POSTGRES_HOST=localhost
