# ── Copy to .env and fill in. compose.yml reads these. ──────────────

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=slang_bench
POSTGRES_PORT=5432

# n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=please-change-this-key

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# Misc
TZ=America/Merida

# LLM providers — dual-API strategy (LiteLLM routes by model-slug prefix)
#  • NVIDIA NIM  → attacker, judge, SIS, and open-weight targets (nvidia_nim/*)
#  • OpenRouter  → highly-aligned "hard" targets (openrouter/*), e.g. Claude, GPT-4o
NVIDIA_API_KEY=
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1

# Only required to run OpenRouter targets (openrouter/anthropic/..., openrouter/openai/...)
OPENROUTER_API_KEY=
# Optional override; LiteLLM defaults to https://openrouter.ai/api/v1
OPENROUTER_API_BASE=
