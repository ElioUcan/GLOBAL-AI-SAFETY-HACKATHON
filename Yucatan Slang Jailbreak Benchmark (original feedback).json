      "id": "fc421451-dc3b-4cc3-a817-753205f08cef",
      "name": "Attack Config",
      "notes": "Valid techniques: translation_transfer, semantic_obfuscation, crescendo, codeswitching, roleplay_wrap, manyshot_slang, pair_refine.\n\nSupported target models (NVIDIA NIM):\n- meta/llama-3.1-8b-instruct\n- mistralai/mistral-7b-instruct-v0.3\n- qwen/qwen2-7b-instruct\n- google/gemma-2-9b-it\n\nbatch_iterations: number of attack runs per execution (default 100)."
    },
    {
      "parameters": {
        "jsCode": "const batchSize = $('Attack Config').first().json.batch_iterations ?? 100;\n\nreturn Array.from({ length: batchSize }, (_, index) => ({\n  json: {\n    iteration: index + 1,\n    batch_total: batchSize,\n  },\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        408,
        320
      ],
      "id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
      "name": "Generate Batch Items",
      "notes": "Creates one item per iteration from Attack Config.batch_iterations (default 100)."
    },
